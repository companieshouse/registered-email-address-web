{
  "name": "registered-email-address-web",
  "version": "1.0.0",
  "description": "Web front-end for Registered Email Address Service",
  "main": "dist/server.js",
  "engines": {
    "node": ">=24.0.0",
    "npm": "^10"
  },
  "scripts": {
    "prebuild": "rm -rf ./dist",
    "build:server": "tsc && cp -r src/views dist/ && cp -r src/config dist/",
    "build": "npm run build:server",
    "lint": "eslint 'src/*.ts' 'src/**/*.ts' 'test/src/**/*.ts'",
    "lint:fix": "eslint 'src/*.ts' 'src/**/*.ts' 'test/src/**/*.ts' --fix",
    "coverage": "jest --all --coverage --passWithNoTests",
    "coverage:report": "nyc --reporter=lcov --reporter=text npm run test",
    "test:coverage": "nyc npm test",
    "sonarqube-base-branch": "sonar-scanner",
    "sonarqube-pull-request": "sonar-scanner -D sonar.pullrequest.base=main",
    "sonarqube": "branch=$(git rev-parse --symbolic-full-name --abbrev-ref HEAD); if [[ $branch == \"HEAD\" ]]; then echo $branch && npm run sonarqube-base-branch; else echo $branch && npm run sonarqube-pull-request; fi;",
    "test": "jest --all",
    "start": "npm run build && node dist/server.js",
    "start:watch": "nodemon",
    "chs-dev": "nodemon --legacy-watch"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm test"
    }
  },
  "author": "Dale Bradley <dbradley@companieshouse.gov.uk>",
  "license": "MIT",
  "dependencies": {
    "@companieshouse/api-sdk-node": "^2.0.331",
    "@companieshouse/node-session-handler": "^5.2.10",
    "@companieshouse/structured-logging-node": "^2.0.11",
    "@companieshouse/web-security-node": "^4.4.15",
    "axios": "^1.13.6",
    "cookie-parser": "^1.4.7",
    "dts": "^0.1.1",
    "eslint-plugin-jest": "^27.9.0",
    "express": "^4.22.1",
    "govuk_frontend_toolkit": "^9.0.1",
    "govuk-elements-sass": "^3.1.3",
    "govuk-frontend": "^4.10.1",
    "helmet": "^7.2.0",
    "helmet-csp": "^3.4.0",
    "http-errors": "^1.8.1",
    "http-status-codes": "^2.3.0",
    "inversify": "^6.2.2",
    "inversify-binding-decorators": "^4.0.0",
    "inversify-dts": "^3.0.0",
    "inversify-express-utils": "^6.4.10",
    "ioredis": "4.31.0",
    "joi": "^17.13.3",
    "js-yaml": "^3.14.2",
    "luxon": "^3.7.2",
    "nocache": "^4.0.0",
    "node-jose": "^2.2.0",
    "node-mocks-http": "^1.17.2",
    "nunjucks": "3.2.4",
    "reflect-metadata": "~0.2.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "typescript-eslint": "^0.0.1-alpha.0",
    "uuid": "8.3.2",
    "yargs": "15.4.1"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "7.1.8",
    "@types/chai-http": "4.2.4",
    "@types/cheerio": "^0.22.35",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/http-errors": "^1.8.2",
    "@types/ioredis": "4.28.10",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^3.12.10",
    "@types/knex": "^0.16.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^12.20.55",
    "@types/node-jose": "^1.1.13",
    "@types/nunjucks": "3.2.6",
    "@types/sinon": "^9.0.11",
    "@types/sinon-chai": "3.2.12",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "7.0.8",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "chai": "4.5.0",
    "chai-as-promised": "7.1.2",
    "chai-http": "^4.4.0",
    "cheerio": "^1.2.0",
    "eslint": "^8.57.1",
    "gulp": "^5.0.1",
    "gulp-clean": "^0.4.0",
    "husky": "^4.3.8",
    "jest": "^29.7.0",
    "nock": "12.0.3",
    "nodemon": "3.1.14",
    "nyc": "^15.1.0",
    "sinon": "9.2.4",
    "sinon-chai": "3.7.0",
    "sonarqube-scanner": "^3.5.0",
    "ts-node": "8.10.2",
    "typescript": "4.9.5"
  },
  "overrides": {
    "glob-parent": "5.1.2",
    "brace-expansion": "5.0.5",
    "minimatch": "10.2.4"
  },
  "nodemonConfig": {
    "watch": [
      "./src"
    ],
    "ext": "ts,js,json,njk,scss,env",
    "legacyWatch": true,
    "ignore": [
      "**/*.test.ts"
    ],
    "exec": "npm run start"
  },
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/companieshouse/rea.web.ch.gov.uk.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/companieshouse/rea.web.ch.gov.uk/issues"
  },
  "homepage": "https://github.com/companieshouse/rea.web.ch.gov.uk#readme"
}
