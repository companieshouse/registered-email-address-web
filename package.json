{
  "name": "registered-email-address-web",
  "version": "1.0.0",
  "description": "Web front-end for Registered Email Address Service",
  "main": "dist/server.js",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11"
  },
  "scripts": {
    "prebuild": "rm -rf ./dist",
    "build:server": "tsc && cp -r src/views dist/ && cp -r src/config dist/",
    "build": "npm run build:server",
    "lint": "eslint 'src/*.ts' 'src/**/*.ts' 'test/src/**/*.ts'",
    "lint:fix": "eslint 'src/*.ts' 'src/**/*.ts' 'test/src/**/*.ts' --fix",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "coverage": "jest --all --coverage --passWithNoTests",
    "coverage:report": "nyc --reporter=lcov --reporter=text npm run test",
    "test:coverage": "nyc npm test",
    "sonarqube-base-branch": "sonar-scanner",
    "sonarqube-pull-request": "sonar-scanner -D sonar.pullrequest.base=main",
    "sonarqube": "branch=$(git rev-parse --symbolic-full-name --abbrev-ref HEAD); if [[ $branch == \"HEAD\" ]]; then echo $branch && npm run sonarqube-base-branch; else echo $branch && npm run sonarqube-pull-request; fi;",
    "test": "jest --all",
    "start": "npm run build && node dist/server.js",
    "start:watch": "nodemon",
    "chs-dev": "nodemon --legacy-watch",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,json}": ["prettier --write"]
  },
  "author": "Dale Bradley <dbradley@companieshouse.gov.uk>",
  "license": "MIT",
  "dependencies": {
    "@companieshouse/api-sdk-node": "^2.0.349",
    "@companieshouse/node-session-handler": "^5.2.14",
    "@companieshouse/structured-logging-node": "^2.0.13",
    "@companieshouse/web-security-node": "^4.4.20",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/baggage-span-processor": "^0.5.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "axios": "^1.17.0",
    "cookie-parser": "^1.4.7",
    "dts": "^0.1.1",
    "eslint-plugin-jest": "^29.15.2",
    "express": "^4.22.2",
    "govuk_frontend_toolkit": "^9.0.1",
    "govuk-elements-sass": "^3.1.3",
    "govuk-frontend": "^4.10.1",
    "helmet": "^8.2.0",
    "helmet-csp": "^4.0.0",
    "http-errors": "^2.0.1",
    "http-status-codes": "^2.3.0",
    "inversify": "^6.2.2",
    "inversify-binding-decorators": "^4.0.0",
    "inversify-dts": "^3.0.0",
    "inversify-express-utils": "^6.4.10",
    "ioredis": "5.11.1",
    "joi": "^18.2.1",
    "js-yaml": "^4.2.0",
    "luxon": "^3.7.2",
    "nocache": "^4.0.0",
    "node-jose": "^2.2.0",
    "node-mocks-http": "^1.17.2",
    "nunjucks": "3.2.4",
    "reflect-metadata": "~0.2.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "typescript-eslint": "^0.0.1-alpha.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "8.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.13.0",
    "@types/node-jose": "^1.1.13",
    "@types/nunjucks": "3.2.6",
    "@types/sinon": "^21.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "chai": "6.2.2",
    "chai-http": "^5.1.2",
    "cheerio": "^1.2.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "gulp": "^5.0.1",
    "gulp-clean": "^0.4.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "nock": "14.0.15",
    "nodemon": "3.1.14",
    "nyc": "^18.0.0",
    "prettier": "^3.8.4",
    "sinon": "21.1.2",
    "sonarqube-scanner": "^4.3.6",
    "ts-node": "10.9.2",
    "typescript": "4.9.5"
  },
  "overrides": {
    "glob-parent": "5.1.2",
    "brace-expansion": "5.0.6",
    "uuid": "^14.0.0",
    "axios": "^1.17.0",
    "protobufjs": "8.5.0"
  },
  "nodemonConfig": {
    "watch": [
      "./src"
    ],
    "ext": "ts,js,json,njk,scss,env",
    "legacyWatch": true,
    "ignore": [
      "**/*.test.ts"
    ],
    "exec": "npm run start"
  },
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/companieshouse/rea.web.ch.gov.uk.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/companieshouse/rea.web.ch.gov.uk/issues"
  },
  "homepage": "https://github.com/companieshouse/rea.web.ch.gov.uk#readme"
}
